        <mxCell id="UJZh2GhYYY2K_crdmEs--44" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;fillColor=#FFB366;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Siège Ymmo&lt;/h1&gt;&lt;p&gt;**Centralise les services : Active Directory, DNS, DHCP, fichiers, sauvegardes, web + base de données Ymmo.&lt;br&gt;**Environ 30 postes + 1 imprimante.&lt;br&gt;**Point de terminaison des tunnels VPN ( endroit où les vpn arrivent )&lt;/p&gt;" vertex="1">
          <mxGeometry height="190" width="190" x="840" y="280" as="geometry" />
        </mxCell>
        <mxCell id="UJZh2GhYYY2K_crdmEs--45" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;fillColor=#66FFFF;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Agences Ymmo&lt;/h1&gt;&lt;p&gt;**12 sites distants identiques, chacun avec ~5 postes + 1 imprimante&lt;/p&gt;&lt;p&gt;&lt;br&gt;**Accès aux services du siège via VPN IPsec.&lt;/p&gt;" vertex="1">
          <mxGeometry height="180" width="210" x="1155" y="280" as="geometry" />
        </mxCell>
        <mxCell id="UJZh2GhYYY2K_crdmEs--46" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;fillColor=#FFCCFF;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;VPN site-à-site IPsec&lt;/h1&gt;&lt;p&gt;**Connexion sécurisée entre chaque agence et le siège&lt;/p&gt;&lt;p&gt;**Chiffrement du trafic et accès au réseau interne comme si tout était local.&lt;/p&gt;" vertex="1">
          <mxGeometry height="150" width="240" x="1155" y="80" as="geometry" />
        </mxCell>
        <mxCell id="UJZh2GhYYY2K_crdmEs--47" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;fillColor=#CCCCCC;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Internet&lt;/h1&gt;&lt;p&gt;**Support de transport des tunnels VPN&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;**Protégé par les firewalls/routeurs de chaque site.&lt;/p&gt;" vertex="1">
          <mxGeometry height="150" width="240" x="840" y="80" as="geometry" />
        </mxCell>
